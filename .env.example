# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit it to version control.

# =============================================================================
# Operational Plane — Backend (FastAPI)
# =============================================================================
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/managed_app
APP_APP_NAME=Managed App
APP_DEBUG=true
APP_ENVIRONMENT=development
APP_ALLOWED_ORIGINS=["http://localhost:5173"]

# External alerting for critical runtime/evolution notifications (optional)
# APP_NOTIFICATION_WEBHOOK_URL=https://alerts.example.test/endpoint
# APP_NOTIFICATION_WEBHOOK_BEARER_TOKEN=
# APP_NOTIFICATION_WEBHOOK_MIN_SEVERITY=critical
# APP_NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=5

# =============================================================================
# Evolving Engine — Runtime Monitoring (MAPE-K Monitor phase)
# =============================================================================

# URL of the Operational Plane backend (via control-plane network in Docker)
ENGINE_MONITOR_URL=http://backend:8000

# How often the autonomous loop polls the Operational Plane (seconds)
ENGINE_MONITOR_INTERVAL_SECONDS=60

# =============================================================================
# Evolving Engine — LLM Provider
# =============================================================================

# "anthropic" or "openai" for API-key based local dev  |  "bedrock" for production (uses EC2 IAM role)
ENGINE_LLM_PROVIDER=anthropic

# Anthropic API key — local dev only (https://console.anthropic.com)
ENGINE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
ENGINE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI API key — optional local/runtime provider (https://platform.openai.com/)
# ENGINE_LLM_PROVIDER=openai
# ENGINE_OPENAI_API_KEY=your_openai_api_key_here
# ENGINE_OPENAI_MODEL=gpt-5.2

# Amazon Bedrock — production (no API key needed; EC2 IAM role grants access)
# ENGINE_LLM_PROVIDER=bedrock
# ENGINE_BEDROCK_REGION=us-east-1
# ENGINE_BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-20250514-v1:0

# =============================================================================
# Evolving Engine — Scope (what the engine can observe and modify)
# =============================================================================

ENGINE_OPERATIONAL_PLANE_PATH=../managed_app
ENGINE_SELF_PATH=.
ENGINE_REPO_ROOT=..
ENGINE_WORKSPACE_PATH=/tmp/evolving_engine_workspace
ENGINE_SANDBOX_TMP_DIR=/tmp
ENGINE_USAGE_STATE_PATH=/tmp/evolving_engine_usage.json
# ENGINE_RUNTIME_CONTRACTS_PATH=/path/to/contracts.yaml

# =============================================================================
# Evolving Engine — Generation & Sandbox
# =============================================================================

ENGINE_MAX_RETRIES=3
ENGINE_MAX_TOKENS=4096

# "docker" (local) | "codebuild" (cloud)
ENGINE_SANDBOX_TYPE=docker
ENGINE_SANDBOX_TIMEOUT_SECONDS=300
ENGINE_DAILY_LLM_CALLS_LIMIT=60
ENGINE_DAILY_INPUT_TOKENS_LIMIT=500000
ENGINE_DAILY_OUTPUT_TOKENS_LIMIT=120000
ENGINE_DAILY_PROACTIVE_RUNS_LIMIT=24
ENGINE_DAILY_FAILED_EVOLUTIONS_LIMIT=10
ENGINE_DAILY_TASK_ATTEMPT_LIMIT=3

# =============================================================================
# Evolving Engine — Deployment
# =============================================================================

ENGINE_GIT_AUTO_COMMIT=true
ENGINE_GIT_BRANCH_PREFIX=evolution
ENGINE_AWS_REGION=us-east-1

# Set after running: make cdk-deploy
# ENGINE_PIPELINE_NAME=self-evolving-software-pipeline

# =============================================================================
# Evolving Engine — Observability
# =============================================================================
ENGINE_LOG_LEVEL=INFO

# =============================================================================
# PostgreSQL (Docker Compose)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=managed_app

# If you run multiple private instances, make these unique per instance.
# The shared open-source repo should keep only templates and examples.
INSTANCE_KEY=base
PUBLIC_HOST=localhost
FRAMEWORK_ROOT=/opt/self-evolving-software
EVOLVED_APP_ROOT=/opt/evolved-app
INSTANCE_STATE_ROOT=/opt/evolved-app/.instance-state
# Runtime Purpose persists here after an operator defines it from the UI.
PURPOSE_PATH=/opt/evolved-app/.instance-state/purpose.yaml
PURPOSE_HISTORY_PATH=/opt/evolved-app/.instance-state/purpose_history
GENESIS_PATH=/opt/evolved-app/.instance-state/genesis.yaml
RUNTIME_CONTRACTS_PATH=/opt/evolved-app/.instance-state/contracts.yaml
COMPOSE_PROJECT=self-evolving-software-base
