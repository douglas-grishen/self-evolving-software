{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host", "0.0.0.0"],
      "port": 5173,
      "cwd": "managed_app/frontend"
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000,
      "cwd": "managed_app/backend"
    },
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres"],
      "port": 5432
    }
  ]
}
