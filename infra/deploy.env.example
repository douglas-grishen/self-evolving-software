# ─────────────────────────────────────────────────────────────────────────────
# Deployment configuration — personal values, NEVER committed to git.
#
# Usage:
#   cp infra/deploy.env.example infra/deploy.env
#   # Fill in your values in infra/deploy.env
#   make cdk-bootstrap   # first time only
#   make cdk-deploy
#
# infra/deploy.env is gitignored. It only lives on your machine.
# ─────────────────────────────────────────────────────────────────────────────

# AWS CLI profile to use for all CDK and AWS CLI commands
AWS_PROFILE=your_aws_profile

# AWS region to deploy into
AWS_REGION=us-east-1

# Your GitHub username or organization (owner of the forked repository)
GITHUB_OWNER=your_github_username

# GitHub repository name (default: self-evolving-software)
GITHUB_REPO=self-evolving-software

# Branch that triggers automatic deployments
GITHUB_BRANCH=main

# AWS CodeConnections ARN for GitHub access.
# To create one:
#   1. AWS Console → Developer Tools → Settings → Connections
#   2. Create connection → GitHub → Authorize
#   3. Copy the ARN shown after creation
CONNECTION_ARN=arn:aws:codeconnections:us-east-1:123456789012:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# (Optional) Restrict SSH access to your IP only — recommended for production.
# Leave blank to allow 0.0.0.0/0 (not recommended).
# SSH_CIDR=203.0.113.10/32
